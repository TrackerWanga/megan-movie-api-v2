<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Megan Movie API - Documentation</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            color: #f0f0f0;
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #e50914 0%, #b20710 100%);
            padding: 40px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: pulse 4s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.1); opacity: 0.5; }
        }

        .header h1 {
            font-size: 3rem;
            font-weight: 700;
            position: relative;
            z-index: 1;
            letter-spacing: -1px;
        }

        .header h1 span {
            background: rgba(255,255,255,0.2);
            padding: 0 10px;
            border-radius: 10px;
        }

        .header p {
            margin-top: 15px;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        .badge {
            display: inline-block;
            background: rgba(0,0,0,0.5);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            margin: 0 5px;
        }

        /* Stats Bar */
        .stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            padding: 20px;
            background: rgba(0,0,0,0.3);
            flex-wrap: wrap;
        }

        .stat-card {
            text-align: center;
            padding: 10px 25px;
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            backdrop-filter: blur(10px);
        }

        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #e50914;
        }

        .stat-label {
            font-size: 0.8rem;
            opacity: 0.7;
        }

        /* Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        /* Search & Filter */
        .filter-bar {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }

        .search-box {
            flex: 1;
            min-width: 200px;
            position: relative;
        }

        .search-box input {
            width: 100%;
            padding: 12px 20px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 30px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: #e50914;
            background: rgba(255,255,255,0.15);
        }

        .category-filters {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 20px;
            background: rgba(255,255,255,0.05);
            border: none;
            border-radius: 30px;
            color: #ddd;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.85rem;
        }

        .filter-btn:hover, .filter-btn.active {
            background: #e50914;
            color: white;
        }

        /* Endpoint Sections */
        .section {
            margin-bottom: 40px;
            background: rgba(255,255,255,0.03);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .section-header {
            background: rgba(0,0,0,0.3);
            padding: 15px 25px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background 0.3s;
        }

        .section-header:hover {
            background: rgba(0,0,0,0.5);
        }

        .section-header h2 {
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-header .badge-count {
            background: #e50914;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
        }

        .toggle-icon {
            font-size: 1.5rem;
            transition: transform 0.3s;
        }

        .section.collapsed .toggle-icon {
            transform: rotate(-90deg);
        }

        .section-content {
            padding: 20px 25px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 15px;
            transition: all 0.3s;
        }

        .section.collapsed .section-content {
            display: none;
        }

        /* Endpoint Card */
        .endpoint-card {
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 15px;
            transition: all 0.3s;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .endpoint-card:hover {
            background: rgba(255,255,255,0.1);
            transform: translateY(-2px);
        }

        .method {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: bold;
            margin-right: 10px;
        }

        .method.get { background: #28a745; }
        .method.post { background: #007bff; }
        .method.put { background: #ffc107; color: #000; }
        .method.delete { background: #dc3545; }

        .endpoint-path {
            font-family: 'Monaco', 'Courier New', monospace;
            font-size: 0.85rem;
            word-break: break-all;
            margin: 10px 0;
            color: #88d4ff;
        }

        .endpoint-desc {
            font-size: 0.8rem;
            opacity: 0.7;
            margin-bottom: 10px;
        }

        .test-btn {
            background: rgba(255,255,255,0.1);
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            color: white;
            cursor: pointer;
            font-size: 0.75rem;
            transition: all 0.3s;
            margin-right: 8px;
        }

        .test-btn:hover {
            background: #e50914;
        }

        .response-area {
            margin-top: 10px;
            background: #0a0a0a;
            border-radius: 8px;
            padding: 10px;
            font-size: 0.7rem;
            font-family: monospace;
            max-height: 200px;
            overflow: auto;
            display: none;
            border: 1px solid #333;
        }

        .response-area.show {
            display: block;
        }

        .response-area pre {
            white-space: pre-wrap;
            word-wrap: break-word;
            margin: 0;
        }

        .loading {
            display: inline-block;
            width: 12px;
            height: 12px;
            border: 2px solid #fff;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 30px;
            border-top: 1px solid rgba(255,255,255,0.05);
            margin-top: 30px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header h1 { font-size: 2rem; }
            .section-content { grid-template-columns: 1fr; }
            .filter-bar { flex-direction: column; }
            .stats { gap: 15px; }
            .stat-card { padding: 5px 15px; }
            .stat-number { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🎬 <span>Megan Movie API</span></h1>
        <p>Your complete movie, TV series, anime, music, and educational content API</p>
        <div style="margin-top: 15px;">
            <span class="badge">🚀 Production Ready</span>
            <span class="badge">🔓 No Auth Required</span>
            <span class="badge">📡 63+ Endpoints</span>
        </div>
    </div>

    <div class="stats">
        <div class="stat-card">
            <div class="stat-number" id="totalEndpoints">63</div>
            <div class="stat-label">Total Endpoints</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">7</div>
            <div class="stat-label">Categories</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">⚡</div>
            <div class="stat-label">&lt;200ms Response</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">🌍</div>
            <div class="stat-label">Global CDN</div>
        </div>
    </div>

    <div class="container">
        <div class="filter-bar">
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="🔍 Search endpoints...">
            </div>
            <div class="category-filters" id="categoryFilters">
                <button class="filter-btn active" data-category="all">All</button>
                <button class="filter-btn" data-category="Search">🔍 Search</button>
                <button class="filter-btn" data-category="Movies">🎬 Movies</button>
                <button class="filter-btn" data-category="TV">📺 TV Series</button>
                <button class="filter-btn" data-category="Music">🎵 Music</button>
                <button class="filter-btn" data-category="Anime">🎌 Anime</button>
                <button class="filter-btn" data-category="Education">📚 Education</button>
                <button class="filter-btn" data-category="Homepage">🏠 Homepage</button>
                <button class="filter-btn" data-category="Sports">⚽ Sports</button>
                <button class="filter-btn" data-category="Kids">👶 Kids</button>
                <button class="filter-btn" data-category="Platforms">🏢 Platforms</button>
            </div>
        </div>

        <div id="endpointsContainer"></div>
    </div>

    <div class="footer">
        <p>© 2025 Megan Movie API | Created with ❤️ by Wanga | Free for all developers</p>
        <p style="font-size: 0.7rem; opacity: 0.5; margin-top: 10px;">All stream URLs are proxied through Megan API - provider domains are hidden</p>
    </div>

    <script>
        const API_BASE = window.location.origin;

        const endpoints = [
            // Search
            { category: "Search", method: "GET", path: "/api/search", desc: "Search all content with type filtering", example: "?q=inception&type=movie" },
            { category: "Search", method: "GET", path: "/api/search/quick", desc: "Fast search without IMDb lookup", example: "?q=inception" },
            { category: "Search", method: "GET", path: "/api/search/types", desc: "Get available content types", example: "" },

            // Movies
            { category: "Movies", method: "GET", path: "/api/movies/{title}", desc: "Complete movie metadata + downloads + streams", example: "Inception?year=2010" },
            { category: "Movies", method: "GET", path: "/api/movies/{title}/downloads", desc: "Get only download URLs", example: "Inception" },

            // TV Series
            { category: "TV", method: "GET", path: "/api/tv/search", desc: "Search TV series only", example: "?q=breaking" },
            { category: "TV", method: "GET", path: "/api/tv/{title}", desc: "Complete TV series metadata + seasons", example: "Breaking%20Bad" },
            { category: "TV", method: "GET", path: "/api/tv/{title}/episode", desc: "Download specific episode", example: "Breaking%20Bad?season=1&episode=1" },
            { category: "TV", method: "GET", path: "/api/tv/{title}/seasons", desc: "Get seasons info", example: "Breaking%20Bad" },

            // Music
            { category: "Music", method: "GET", path: "/api/music/search", desc: "Search music videos", example: "?q=pharrell" },
            { category: "Music", method: "GET", path: "/api/music/artist/{name}", desc: "Music by artist name", example: "pharrell" },
            { category: "Music", method: "GET", path: "/api/music/trending", desc: "Get trending music", example: "" },
            { category: "Music", method: "GET", path: "/api/music/popular", desc: "Get popular music", example: "" },
            { category: "Music", method: "GET", path: "/api/music/latest", desc: "Get latest music", example: "" },
            { category: "Music", method: "GET", path: "/api/music/{detail_path}", desc: "Complete music video details", example: "pharrell-williams..." },
            { category: "Music", method: "GET", path: "/api/music/download/{detail_path}", desc: "Music video download URL", example: "pharrell-williams..." },

            // Anime
            { category: "Anime", method: "GET", path: "/api/anime/search", desc: "Search anime", example: "?q=naruto" },
            { category: "Anime", method: "GET", path: "/api/anime/popular", desc: "Get popular anime", example: "" },
            { category: "Anime", method: "GET", path: "/api/anime/trending", desc: "Get trending anime", example: "" },
            { category: "Anime", method: "GET", path: "/api/anime/latest", desc: "Get latest anime", example: "" },
            { category: "Anime", method: "GET", path: "/api/anime/{detail_path}", desc: "Complete anime details", example: "naruto" },
            { category: "Anime", method: "GET", path: "/api/anime/{detail_path}/episode", desc: "Anime episode download", example: "naruto?season=1&episode=1" },

            // Education
            { category: "Education", method: "GET", path: "/api/education/search", desc: "Search educational content", example: "?q=python" },
            { category: "Education", method: "GET", path: "/api/education/documentaries", desc: "Documentary content", example: "" },
            { category: "Education", method: "GET", path: "/api/education/tutorials", desc: "Tutorial content", example: "" },
            { category: "Education", method: "GET", path: "/api/education/popular", desc: "Popular educational content", example: "" },
            { category: "Education", method: "GET", path: "/api/education/trending", desc: "Trending educational content", example: "" },
            { category: "Education", method: "GET", path: "/api/education/latest", desc: "Latest educational content", example: "" },
            { category: "Education", method: "GET", path: "/api/education/{detail_path}", desc: "Complete education details", example: "python-tutorial" },
            { category: "Education", method: "GET", path: "/api/education/download/{detail_path}", desc: "Education download URL", example: "python-tutorial" },

            // Homepage/Banners
            { category: "Homepage", method: "GET", path: "/api/homepage/banners", desc: "Main hero banners", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/trending", desc: "Trending content", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/action", desc: "Action movies", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/horror", desc: "Horror movies", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/romance", desc: "Romance movies", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/adventure", desc: "Adventure movies", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/anime", desc: "Anime", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/kdrama", desc: "K-Drama", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/cdrama", desc: "C-Drama", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/turkish", desc: "Turkish drama", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/sadrama", desc: "SA Drama", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/blackshows", desc: "Must-watch Black shows", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/premium", desc: "Premium VIP content", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/hot-shorts", desc: "Hot Short TV", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/learn-english", desc: "Learn English with Movies", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/nigerian-skit", desc: "Nigerian skit", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/movies-in-minutes", desc: "Movies in minutes", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/viral-sports", desc: "Viral sports shorts", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/trending-club", desc: "Trending club picks", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/kung-fu", desc: "Secrets of Asian Kung Fu", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/kdrama-shorts", desc: "K-Drama shorts", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/box-office", desc: "Global BoxOffice", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/fan-favorites", desc: "Fan favorites", example: "" },
            { category: "Homepage", method: "GET", path: "/api/homepage/upcoming", desc: "Upcoming calendar", example: "" },

            // Sports
            { category: "Sports", method: "GET", path: "/api/sports/wwe", desc: "WWE content", example: "" },
            { category: "Sports", method: "GET", path: "/api/sports/football", desc: "Football highlights", example: "" },
            { category: "Sports", method: "GET", path: "/api/sports/boxing", desc: "Boxing/fight zone", example: "" },
            { category: "Sports", method: "GET", path: "/api/sports/live", desc: "Live sports", example: "" },

            // Kids
            { category: "Kids", method: "GET", path: "/api/kids/nursery", desc: "Nursery rhymes", example: "" },
            { category: "Kids", method: "GET", path: "/api/kids/animation", desc: "Animation collection", example: "" },

            // Platforms
            { category: "Platforms", method: "GET", path: "/api/platforms", desc: "Platform banners", example: "" }
        ];

        function buildEndpointCard(ep) {
            const fullUrl = API_BASE + ep.path.replace(/{[^}]+}/g, 'test');
            const testId = `test-${Date.now()}-${Math.random()}`;

            return `
                <div class="endpoint-card" data-category="${ep.category}" data-name="${ep.path.toLowerCase()}">
                    <div>
                        <span class="method ${ep.method.toLowerCase()}">${ep.method}</span>
                        <span style="font-size: 0.8rem; opacity: 0.6;">${ep.category}</span>
                    </div>
                    <div class="endpoint-path">${ep.path}</div>
                    <div class="endpoint-desc">${ep.desc}</div>
                    ${ep.example ? `<div style="font-size: 0.7rem; opacity: 0.5; margin-bottom: 8px;">📝 Example: ${ep.example}</div>` : ''}
                    <div>
                        <button class="test-btn" onclick="testEndpoint('${ep.path}', '${testId}')">🧪 Test</button>
                        <button class="test-btn" onclick="copyUrl('${ep.path}')">📋 Copy URL</button>
                    </div>
                    <div id="${testId}" class="response-area">
                        <pre>Click Test to see response...</pre>
                    </div>
                </div>
            `;
        }

        function renderEndpoints(filter = 'all', search = '') {
            const container = document.getElementById('endpointsContainer');
            const sections = {};

            let filtered = endpoints.filter(ep => {
                if (filter !== 'all' && ep.category !== filter) return false;
                if (search && !ep.path.toLowerCase().includes(search.toLowerCase()) && !ep.desc.toLowerCase().includes(search.toLowerCase())) return false;
                return true;
            });

            // Group by category
            filtered.forEach(ep => {
                if (!sections[ep.category]) sections[ep.category] = [];
                sections[ep.category].push(ep);
            });

            // Get category order
            const categoryOrder = ['Search', 'Movies', 'TV', 'Music', 'Anime', 'Education', 'Homepage', 'Sports', 'Kids', 'Platforms'];

            let html = '';
            for (const cat of categoryOrder) {
                if (sections[cat] && sections[cat].length > 0) {
                    html += `
                        <div class="section" id="section-${cat.toLowerCase()}">
                            <div class="section-header" onclick="toggleSection('${cat.toLowerCase()}')">
                                <h2>
                                    <span>${getCategoryIcon(cat)}</span> ${cat}
                                    <span class="badge-count">${sections[cat].length}</span>
                                </h2>
                                <div class="toggle-icon">▼</div>
                            </div>
                            <div class="section-content">
                                ${sections[cat].map(ep => buildEndpointCard(ep)).join('')}
                            </div>
                        </div>
                    `;
                }
            }

            container.innerHTML = html || '<div style="text-align: center; padding: 50px;">No endpoints found</div>';
            document.getElementById('totalEndpoints').innerText = filtered.length;
        }

        function getCategoryIcon(cat) {
            const icons = {
                'Search': '🔍',
                'Movies': '🎬',
                'TV': '📺',
                'Music': '🎵',
                'Anime': '🎌',
                'Education': '📚',
                'Homepage': '🏠',
                'Sports': '⚽',
                'Kids': '👶',
                'Platforms': '🏢'
            };
            return icons[cat] || '📁';
        }

        async function testEndpoint(path, responseId) {
            const responseDiv = document.getElementById(responseId);
            if (!responseDiv) return;

            // Show loading
            responseDiv.classList.add('show');
            responseDiv.innerHTML = '<pre><span class="loading"></span> Loading...</pre>';

            // Build URL with example params
            let fullPath = path;
            let testUrl = API_BASE + fullPath;

            // Add example parameters if needed
            if (fullPath.includes('{title}') && !fullPath.includes('/episode')) {
                testUrl = API_BASE + fullPath.replace('{title}', 'Inception');
                if (fullPath.includes('downloads')) {
                    testUrl = API_BASE + fullPath.replace('{title}', 'Inception');
                }
            } else if (fullPath.includes('{title}/episode')) {
                testUrl = API_BASE + fullPath.replace('{title}', 'Breaking%20Bad') + '?season=1&episode=1';
            } else if (fullPath.includes('{name}')) {
                testUrl = API_BASE + fullPath.replace('{name}', 'pharrell');
            } else if (fullPath.includes('{detail_path}')) {
                testUrl = API_BASE + fullPath.replace('{detail_path}', 'inception-e1BOR6f19C7');
            } else if (fullPath === '/api/search' || fullPath === '/api/search/quick') {
                testUrl = API_BASE + fullPath + '?q=inception';
            } else if (fullPath === '/api/tv/search') {
                testUrl = API_BASE + fullPath + '?q=breaking';
            } else if (fullPath === '/api/music/search') {
                testUrl = API_BASE + fullPath + '?q=pharrell';
            } else if (fullPath === '/api/anime/search') {
                testUrl = API_BASE + fullPath + '?q=naruto';
            } else if (fullPath === '/api/education/search') {
                testUrl = API_BASE + fullPath + '?q=python';
            }

            try {
                const response = await fetch(testUrl);
                const data = await response.json();
                responseDiv.innerHTML = `<pre>${JSON.stringify(data, null, 2)}</pre>`;
            } catch (error) {
                responseDiv.innerHTML = `<pre>❌ Error: ${error.message}</pre>`;
            }
        }

        function copyUrl(path) {
            let url = API_BASE + path;
            if (path.includes('{title}')) {
                url = API_BASE + path.replace('{title}', 'Inception');
            } else if (path.includes('{name}')) {
                url = API_BASE + path.replace('{name}', 'pharrell');
            } else if (path.includes('{detail_path}')) {
                url = API_BASE + path.replace('{detail_path}', 'inception-e1BOR6f19C7');
            }

            navigator.clipboard.writeText(url);
            alert('✅ URL copied to clipboard!');
        }

        function toggleSection(cat) {
            const section = document.getElementById(`section-${cat}`);
            if (section) {
                section.classList.toggle('collapsed');
            }
        }

        // Event listeners
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const activeFilter = document.querySelector('.filter-btn.active')?.dataset.category || 'all';
            renderEndpoints(activeFilter, e.target.value);
        });

        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                renderEndpoints(btn.dataset.category, document.getElementById('searchInput').value);
            });
        });

        // Initial render
        renderEndpoints('all', '');
    </script>
</body>
</html>
